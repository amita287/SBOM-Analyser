# Copy to `.env` and fill in. The analyzer runs fully with LLM_PROVIDER=none
# (deterministic fallbacks only) — the LLM is an enhancement, never a dependency.

# Which LLM backend to use: none | openai | anthropic
#   openai = any OpenAI-compatible endpoint (OpenAI, OpenRouter, Ollama, vLLM, ...)
LLM_PROVIDER=none

# API key for the selected provider. Leave blank when LLM_PROVIDER=none.
LLM_API_KEY=

# Model id for the selected provider, e.g.
#   anthropic -> claude-opus-4-8            (default when blank)
#   openai    -> gpt-4o-mini                (required; no default)
#   openrouter-> anthropic/claude-opus-4-8  (provider-prefixed)
# Leave blank when LLM_PROVIDER=none.
LLM_MODEL=

# Base URL for OpenAI-compatible endpoints. Ignored by the anthropic provider.
# Defaults to https://api.openai.com/v1
#   OpenRouter -> https://openrouter.ai/api/v1
#   Ollama     -> http://localhost:11434/v1
LLM_BASE_URL=

# Do LLM adjudications (Reasoners A/B) feed the risk score?
#   false (default) — advisory only: the verdicts are recorded on the report but
#                     the score stays 100% deterministic. This honours the rule
#                     "never use an LLM to produce numbers that feed a metric".
#   true            — Reasoner A's exploitability bucket and Reasoner B's
#                     false-positive verdict override the deterministic ones.
#                     Bounded (3 buckets), but it CAN move risk_score.
LLM_AFFECTS_SCORE=false

# Cap on how many findings get LLM enrichment (riskiest first), so a demo run
# stays cheap. Narratives and remediation playbooks respect this too.
LLM_MAX_FINDINGS=10

# Per-call output token budget. Lower it if your provider rejects the request on
# cost grounds — OpenRouter returns HTTP 402 when max_tokens exceeds your
# remaining credit ("you requested 1024 tokens but can only afford 731").
LLM_MAX_TOKENS=1024
