# Copy to `.env` and fill in. The analyzer runs fully with LLM_PROVIDER=none
# (deterministic fallbacks only) — the LLM is an enhancement, never a dependency.

# Which LLM backend to use: none | openai | anthropic
LLM_PROVIDER=none

# API key for the selected provider. Leave blank when LLM_PROVIDER=none.
LLM_API_KEY=

# Model id for the selected provider, e.g.
#   anthropic -> claude-sonnet-5
#   openai    -> gpt-4o-mini
# Leave blank when LLM_PROVIDER=none.
LLM_MODEL=
