{# Phase 7, Section 9.2 — self-contained HTML report.
   No external CSS/JS/fonts: this file must open correctly from disk, offline,
   and survive being emailed around as a single attachment. #}
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>SBOM Risk Report — {{ report.run_id }}</title>
<style>
  :root {
    --critical: #dc2626;
    --high:     #ea580c;
    --medium:   #d97706;
    --low:      #16a34a;
    --none:     #94a3b8;

    --ink:      #0f172a;
    --ink-soft: #475569;
    --ink-faint:#94a3b8;
    --line:     #e2e8f0;
    --panel:    #ffffff;
    --bg:       #f1f5f9;
    --accent:   #4f46e5;
  }

  * { box-sizing: border-box; }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--ink);
    font: 15px/1.55 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
          "Helvetica Neue", Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
  }
  .wrap { max-width: 1180px; margin: 0 auto; padding: 0 24px 72px; }
  code, .mono {
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas,
                 "Liberation Mono", monospace;
    font-size: 0.92em;
  }
  a { color: var(--accent); }

  /* ---------- masthead ---------- */
  header.masthead {
    background: linear-gradient(135deg, #1e1b4b 0%, #312e81 55%, #4338ca 100%);
    color: #e0e7ff;
    padding: 34px 0 30px;
    margin-bottom: 28px;
  }
  header.masthead .wrap { padding-bottom: 0; }
  .masthead h1 {
    margin: 0 0 6px;
    font-size: 27px;
    letter-spacing: -0.015em;
    color: #fff;
  }
  .masthead .sub { color: #a5b4fc; font-size: 14px; }
  .masthead .meta {
    margin-top: 18px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 5px 12px;
    border-radius: 999px;
    font-size: 12.5px;
    background: rgba(255,255,255,0.10);
    border: 1px solid rgba(255,255,255,0.18);
    color: #e0e7ff;
  }
  .pill b { color: #fff; font-weight: 600; }
  .pill.warn { background: rgba(234,88,12,0.22); border-color: rgba(251,146,60,0.5); }
  .pill.good { background: rgba(22,163,74,0.20); border-color: rgba(74,222,128,0.45); }

  /* ---------- KPI strip ---------- */
  .kpis {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 12px;
    margin-bottom: 26px;
  }
  .kpi {
    background: var(--panel);
    border: 1px solid var(--line);
    border-top: 3px solid var(--tone, var(--none));
    border-radius: 10px;
    padding: 14px 16px;
  }
  .kpi .n { font-size: 26px; font-weight: 650; letter-spacing: -0.02em; }
  .kpi .l {
    font-size: 11.5px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
    margin-top: 2px;
  }

  /* ---------- generic card ---------- */
  section.card {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 20px 22px;
    margin-bottom: 22px;
  }
  section.card > h2 {
    margin: 0 0 4px;
    font-size: 16px;
    letter-spacing: -0.01em;
  }
  section.card > .hint {
    margin: 0 0 16px;
    color: var(--ink-soft);
    font-size: 13px;
  }

  /* ---------- tables ---------- */
  table { width: 100%; border-collapse: collapse; }
  th {
    text-align: left;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--ink-faint);
    font-weight: 600;
    padding: 0 10px 8px 0;
    border-bottom: 1px solid var(--line);
  }
  td {
    padding: 9px 10px 9px 0;
    border-bottom: 1px solid #f1f5f9;
    vertical-align: middle;
  }
  tbody tr:last-child td { border-bottom: 0; }
  td.num, th.num { text-align: right; padding-right: 0; }

  /* ---------- severity ---------- */
  .dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    display: inline-block;
    flex: 0 0 auto;
    background: var(--tone);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--tone) 18%, transparent);
  }
  .sev-critical { --tone: var(--critical); }
  .sev-high     { --tone: var(--high); }
  .sev-medium   { --tone: var(--medium); }
  .sev-low      { --tone: var(--low); }
  .sev-none     { --tone: var(--none); }

  .chip {
    display: inline-block;
    padding: 2px 9px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #fff;
    background: var(--tone);
  }
  .score { font-weight: 650; font-variant-numeric: tabular-nums; color: var(--tone); }

  .tag {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 5px;
    font-size: 11px;
    font-weight: 500;
    background: #f1f5f9;
    color: var(--ink-soft);
    border: 1px solid var(--line);
    white-space: nowrap;
  }
  .tag.vulnerable            { background:#fef2f2; color:#b91c1c; border-color:#fecaca; }
  .tag.transitive_vulnerable { background:#fff7ed; color:#c2410c; border-color:#fed7aa; }
  .tag.license_conflict      { background:#faf5ff; color:#7e22ce; border-color:#e9d5ff; }
  .tag.unmaintained          { background:#fefce8; color:#a16207; border-color:#fde68a; }
  .tag.clean                 { background:#f0fdf4; color:#15803d; border-color:#bbf7d0; }

  /* ---------- app sections ---------- */
  .app {
    background: var(--panel);
    border: 1px solid var(--line);
    border-left: 5px solid var(--tone);
    border-radius: 12px;
    margin-bottom: 16px;
    overflow: hidden;
  }
  .app > summary {
    cursor: pointer;
    list-style: none;
    padding: 16px 20px;
    display: grid;
    grid-template-columns: 30px 1fr auto auto;
    align-items: center;
    gap: 14px;
  }
  .app > summary::-webkit-details-marker { display: none; }
  .app > summary:hover { background: #fafbfc; }
  .app .rank {
    font-size: 13px;
    font-weight: 650;
    color: var(--ink-faint);
    font-variant-numeric: tabular-nums;
  }
  .app .name { font-weight: 600; letter-spacing: -0.01em; }
  .app .name .id { color: var(--ink-faint); font-weight: 400; margin-left: 8px; font-size: 12.5px; }
  .app .facts { color: var(--ink-soft); font-size: 12.5px; }
  .app .appscore { text-align: right; }
  .app .appscore .n { font-size: 22px; font-weight: 650; color: var(--tone); font-variant-numeric: tabular-nums; }
  .app .appscore .l { font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--ink-faint); }
  .app .body { padding: 4px 20px 18px; border-top: 1px solid var(--line); }

  /* ---------- finding ---------- */
  .finding { border-bottom: 1px solid #f1f5f9; }
  .finding:last-child { border-bottom: 0; }
  .finding > summary {
    cursor: pointer;
    list-style: none;
    padding: 11px 0;
    display: grid;
    grid-template-columns: 12px minmax(220px, 1.6fr) 1fr auto 58px;
    align-items: center;
    gap: 12px;
  }
  .finding > summary::-webkit-details-marker { display: none; }
  .finding > summary:hover .lib { color: var(--accent); }
  .finding .lib { font-weight: 550; }
  .finding .lib .v { color: var(--ink-faint); font-weight: 400; }
  .finding .tags { display: flex; flex-wrap: wrap; gap: 5px; }
  .finding .eco { font-size: 12px; color: var(--ink-faint); }
  .finding > summary .score { text-align: right; }
  .finding .panel {
    padding: 4px 0 20px 24px;
    border-left: 2px solid var(--line);
    margin-left: 4px;
  }

  .facts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 12px;
    margin-bottom: 16px;
  }
  .fact { background: #f8fafc; border: 1px solid var(--line); border-radius: 8px; padding: 9px 12px; }
  .fact .k {
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-faint);
  }
  .fact .v { font-weight: 550; margin-top: 1px; }

  h4.blk {
    margin: 18px 0 8px;
    font-size: 11.5px;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--ink-faint);
  }

  .cve { font-weight: 600; }
  .strike { text-decoration: line-through; color: var(--ink-faint); }
  .fp-note {
    font-size: 12px;
    color: #15803d;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 5px;
    padding: 1px 7px;
    white-space: nowrap;
  }

  .path {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    padding: 9px 12px;
    background: #f8fafc;
    border: 1px solid var(--line);
    border-radius: 8px;
    margin-bottom: 8px;
  }
  .hop {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 5px;
    padding: 2px 8px;
    font-size: 12.5px;
  }
  .hop.entry { border-color: #c7d2fe; background: #eef2ff; color: #3730a3; font-weight: 550; }
  .hop.victim { border-color: #fecaca; background: #fef2f2; color: #b91c1c; font-weight: 550; }
  .arrow { color: var(--ink-faint); font-size: 12px; }

  .narrative {
    margin: 0;
    padding: 12px 14px;
    background: #eef2ff;
    border: 1px solid #c7d2fe;
    border-left: 3px solid var(--accent);
    border-radius: 8px;
    color: #312e81;
    font-size: 13.5px;
  }
  .narrative .src {
    display: block;
    margin-top: 7px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #6366f1;
  }

  .remediation { display: flex; align-items: flex-start; gap: 12px; }
  .prio {
    flex: 0 0 auto;
    font-weight: 700;
    font-size: 12px;
    padding: 3px 9px;
    border-radius: 6px;
    color: #fff;
  }
  .prio.P1 { background: var(--critical); }
  .prio.P2 { background: var(--high); }
  .prio.P3 { background: var(--none); }
  .remediation ol { margin: 0; padding-left: 20px; }
  .remediation li { margin-bottom: 4px; }

  .clean-roll > summary {
    cursor: pointer;
    padding: 12px 0 4px;
    color: var(--ink-soft);
    font-size: 13px;
  }
  .clean-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: 4px 16px;
    padding: 10px 0 4px;
    font-size: 12.5px;
    color: var(--ink-soft);
  }

  .callout {
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-radius: 8px;
    padding: 11px 14px;
    font-size: 13.5px;
    color: #92400e;
  }
  .legend { display: flex; flex-wrap: wrap; gap: 16px; font-size: 12.5px; color: var(--ink-soft); }
  .legend span { display: inline-flex; align-items: center; gap: 6px; }
  footer.foot {
    color: var(--ink-faint);
    font-size: 12.5px;
    text-align: center;
    padding-top: 8px;
  }
</style>
</head>
<body>

<header class="masthead">
  <div class="wrap">
    <h1>Software Supply Chain Risk Report</h1>
    <div class="sub">{{ report.apps | length }} applications &middot; {{ total_deps }} dependency occurrences analysed</div>
    <div class="meta">
      <span class="pill">run <b>{{ report.run_id }}</b></span>
      <span class="pill">as of <b>{{ report.generated_at.date().isoformat() }}</b></span>
      {% if report.llm_provider == "none" %}
        <span class="pill good">✓ fully deterministic — no LLM</span>
      {% else %}
        {% if report.llm_affects_score %}
          <span class="pill warn">⚠ LLM ({{ report.llm_provider }}) is feeding risk scores</span>
        {% else %}
          <span class="pill">LLM <b>{{ report.llm_provider }}</b> — advisory only, scores deterministic</span>
        {% endif %}
        {# Configured is not the same as working. If the calls failed, say so here
           rather than letting the reader assume the model wrote the narratives. #}
        {% if report.llm_fallbacks and report.llm_fallbacks == report.llm_calls %}
          <span class="pill warn">⚠ every LLM call failed — all text below is deterministic fallback</span>
        {% elif report.llm_fallbacks %}
          <span class="pill warn">⚠ {{ report.llm_fallbacks }} of {{ report.llm_calls }} LLM calls fell back</span>
        {% endif %}
      {% endif %}
    </div>
  </div>
</header>

<div class="wrap">

  {# ---------------- KPI strip ---------------- #}
  <div class="kpis">
    <div class="kpi sev-critical" style="--tone: var(--critical)">
      <div class="n">{{ totals.vulnerable }}</div><div class="l">Vulnerable</div>
    </div>
    <div class="kpi" style="--tone: var(--high)">
      <div class="n">{{ totals.transitive_vulnerable }}</div><div class="l">Transitively exposed</div>
    </div>
    <div class="kpi" style="--tone: #7e22ce">
      <div class="n">{{ totals.license_conflict }}</div><div class="l">License conflicts</div>
    </div>
    <div class="kpi" style="--tone: var(--medium)">
      <div class="n">{{ totals.unmaintained }}</div><div class="l">Unmaintained</div>
    </div>
    <div class="kpi" style="--tone: var(--low)">
      <div class="n">{{ totals.clean }}</div><div class="l">Clean</div>
    </div>
  </div>

  {# ---------------- top-N riskiest ---------------- #}
  <section class="card">
    <h2>Top {{ report.summary.top_riskiest | length }} riskiest dependencies</h2>
    <p class="hint">Across every application, ranked by dependency risk score (Section 7.1).</p>
    <table>
      <thead>
        <tr>
          <th style="width:26px"></th>
          <th>Library</th>
          <th>Version</th>
          <th>Application</th>
          <th>Severity</th>
          <th class="num">Score</th>
        </tr>
      </thead>
      <tbody>
      {% for d in report.summary.top_riskiest %}
        <tr class="sev-{{ d.severity.value }}">
          <td><span class="dot"></span></td>
          <td><b>{{ d.library_name }}</b></td>
          <td class="mono">{{ d.version }}</td>
          <td>{{ app_names.get(d.app_id, d.app_id) }}</td>
          <td><span class="chip">{{ d.severity.value }}</span></td>
          <td class="num score">{{ "%.1f" | format(d.risk_score) }}</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </section>

  {% if report.summary.dedup_note %}
  <section class="card">
    <h2>Blast radius</h2>
    <p class="hint">A shared vulnerable library is reported once per app, but linked by library + version so the team sees the true reach.</p>
    <div class="callout">{{ report.summary.dedup_note }}</div>
  </section>
  {% endif %}

  {# ---------------- per-app ---------------- #}
  <section class="card">
    <h2>Applications</h2>
    <p class="hint">Sorted by application risk score, highest first. Expand an app for its ranked findings.</p>
    <div class="legend">
      <span class="sev-critical"><i class="dot"></i> critical &ge; 75</span>
      <span class="sev-high"><i class="dot"></i> high &ge; 50</span>
      <span class="sev-medium"><i class="dot"></i> medium &ge; 25</span>
      <span class="sev-low"><i class="dot"></i> low &gt; 0</span>
      <span class="sev-none"><i class="dot"></i> none</span>
    </div>
  </section>

  {% for app in apps %}
  <details class="app sev-{{ app.severity.value }}" {% if loop.index <= 3 %}open{% endif %}>
    <summary>
      <span class="rank">#{{ loop.index }}</span>
      <span>
        <div class="name">{{ app.name }}<span class="id mono">{{ app.app_id }}</span></div>
        <div class="facts">
          {{ app.business_criticality.value }} criticality &middot;
          {{ app.findings | length }} deps &middot;
          {{ at_risk_counts[app.app_id] }} at risk
        </div>
      </span>
      <span><span class="chip">{{ app.severity.value }}</span></span>
      <span class="appscore">
        <div class="n">{{ "%.1f" | format(app.app_score) }}</div>
        <div class="l">app score</div>
      </span>
    </summary>

    <div class="body">
      {% set risky = app.findings | selectattr("is_risk") | list %}
      {% set clean = app.findings | rejectattr("is_risk") | list %}

      {% for f in risky %}
      <details class="finding sev-{{ f.severity.value }}">
        <summary>
          <span class="dot"></span>
          <span class="lib">{{ f.library_name }} <span class="v mono">{{ f.version }}</span></span>
          <span class="tags">
            {% for rt in f.risk_types %}
              <span class="tag {{ rt.value }}">{{ rt.value | replace("_", " ") }}</span>
            {% endfor %}
          </span>
          <span class="eco">{{ f.ecosystem.value }}</span>
          <span class="score">{{ "%.1f" | format(f.risk_score) }}</span>
        </summary>

        <div class="panel">
          <div class="facts-grid">
            <div class="fact">
              <div class="k">License</div>
              <div class="v">{{ f.license or "unknown" }} &middot; {{ f.license_outcome.value }}</div>
            </div>
            {% if f.maintenance %}
            <div class="fact">
              <div class="k">Last updated</div>
              <div class="v">
                {{ f.maintenance.last_updated.isoformat() }}
                ({{ "%.1f" | format(f.maintenance.age_years) }}y{% if f.maintenance.is_stale %}, stale{% endif %})
              </div>
            </div>
            {% endif %}
            <div class="fact">
              <div class="k">Dependency</div>
              <div class="v mono">{{ f.dependency_id }}</div>
            </div>
            {% if f.matched_cves %}
            <div class="fact">
              <div class="k">Exploitability</div>
              <div class="v">{{ (f.matched_cves[0].exploitability.value if f.matched_cves[0].exploitability else "—") | replace("_", " ") }}</div>
            </div>
            {% endif %}
          </div>

          {% if f.matched_cves %}
          <h4 class="blk">Matched CVEs</h4>
          <table>
            <thead>
              <tr>
                <th>CVE</th>
                <th>CVSS</th>
                <th>Affected range</th>
                <th>Fix</th>
                <th class="num">Contribution</th>
              </tr>
            </thead>
            <tbody>
            {% for c in f.matched_cves %}
              <tr>
                <td class="cve {% if c.is_false_positive %}strike{% endif %}">{{ c.cve_id }}</td>
                <td>{{ "%.1f" | format(c.cvss_score) }} <span class="tag">{{ c.cvss_severity.value }}</span></td>
                <td class="mono">{{ c.affected_versions }}</td>
                <td>
                  {%- if c.is_false_positive -%}
                    <span class="fp-note">backported patch — not exploitable</span>
                  {%- elif c.patch_available -%}
                    upgrade to <b class="mono">{{ c.fixed_version }}</b>
                  {%- else -%}
                    <span class="tag">no patch</span>
                  {%- endif -%}
                </td>
                <td class="num">{{ "%.1f" | format(c.cve_score) }}</td>
              </tr>
            {% endfor %}
            </tbody>
          </table>
          {% endif %}

          {% if f.attack_paths %}
          <h4 class="blk">Attack paths ({{ f.attack_paths | length }})</h4>
          {% for p in f.attack_paths %}
            <div class="path">
              {% for node in p.path %}
                {% if not loop.first %}<span class="arrow">&rarr;</span>{% endif %}
                <span class="hop {% if loop.first %}entry{% elif loop.last %}victim{% endif %}">{{ node_labels.get(node, node) }}</span>
              {% endfor %}
              {% if p.cve_id %}<span class="arrow">&rarr;</span><span class="tag vulnerable">{{ p.cve_id }}</span>{% endif %}
            </div>
          {% endfor %}
          {% endif %}

          {% if f.narrative %}
          <h4 class="blk">Attack-chain narrative</h4>
          <p class="narrative">
            {{ f.narrative }}
            {# Credit the model only where it actually produced the text. #}
            <span class="src">{% if f.llm_enriched %}generated by {{ report.llm_provider }}{% else %}deterministic template{% endif %}</span>
          </p>
          {% endif %}

          {% if f.remediation and f.remediation.steps %}
          <h4 class="blk">Remediation</h4>
          <div class="remediation">
            <span class="prio {{ f.remediation.priority }}">{{ f.remediation.priority }}</span>
            <ol>
              {% for step in f.remediation.steps %}<li>{{ step }}</li>{% endfor %}
            </ol>
          </div>
          {% endif %}
        </div>
      </details>
      {% endfor %}

      {% if clean %}
      <details class="clean-roll">
        <summary>{{ clean | length }} clean {{ "dependency" if clean | length == 1 else "dependencies" }} — no risk detected</summary>
        <div class="clean-list">
          {% for f in clean %}
            <div>{{ f.library_name }} <span class="mono" style="color:var(--ink-faint)">{{ f.version }}</span></div>
          {% endfor %}
        </div>
      </details>
      {% endif %}
    </div>
  </details>
  {% endfor %}

  <footer class="foot">
    Generated from <code>reports/analysis.json</code> &middot; scores are deterministic (Section 7);
    the LLM never produces a number that feeds a metric.
  </footer>
</div>
</body>
</html>
