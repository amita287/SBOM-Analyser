# The dataset is the OFFICIAL hackathon input and is COMMITTED. It used to be
# generated (and therefore ignored); the generator is gone and `data/` now holds
# the six supplied files, including the ground-truth labels. Ignoring it meant a
# fresh clone had no data and the app could not start.
#
# `.env` stays ignored — that is where the API key lives.

# Analysis output — regenerated by `python scripts/run_analysis.py`
/reports/*
!/reports/.gitkeep

# Secrets
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# Tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# SQLite run history (optional feature)
*.sqlite
*.db
